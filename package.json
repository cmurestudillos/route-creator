{
  "name": "route-creator",
  "version": "1.1.0",
  "description": "Aplicación para crear rutas de MTB, ciclismo en ruta y autocaravanas y exportarlas como GPX",
  "main": "main.js",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "start": "electron .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package:mac": "electron-builder build --mac",
    "package:win": "electron-builder build --windows",
    "package:linux": "electron-builder build --linux"
  },
  "author": "Carlos Mur",
  "license": "MIT",
  "dependencies": {
    "fast-xml-parser": "^5.7.0",
    "leaflet": "^1.9.4",
    "localforage": "^1.10.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "electron": "^39.8.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "prettier": "^3.8.3"
  },
  "pnpm": {
    "allowedBuildScripts": ["electron", "electron-winstaller"]
  },
  "build": {
    "appId": "com.cmurestudillos.routecreator",
    "productName": "Route Creator",
    "directories": {
      "output": "release/"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns"
    },
    "win": {
      "icon": "assets/icon.ico"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Development"
    }
  }
}
